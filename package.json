{
  "name": "pattern-golf",
  "private": true,
  "version": "0.0.0",
  "description": "A daily regex-golf puzzle with a live match judge and a shareable result grid.",
  "type": "module",
  "license": "MIT",
  "author": "Charlie Krug",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/pattern-golf.git"
  },
  "homepage": "https://github.com/ctkrug/pattern-golf#readme",
  "bugs": {
    "url": "https://github.com/ctkrug/pattern-golf/issues"
  },
  "keywords": [
    "regex",
    "puzzle",
    "game",
    "daily-puzzle",
    "wordle-like"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
